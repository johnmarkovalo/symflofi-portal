NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://your-dsn@xxx.ingest.sentry.io/xxx

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# VPS proxy (device remote access)
VPS_API_URL=http://api.symflofi.cloud

# Resend (set as Supabase Edge Function secret via: supabase secrets set RESEND_API_KEY=re_...)
# RESEND_API_KEY=re_your-api-key
# OTP_FROM_EMAIL=noreply@symflofi.cloud
